# Pipeline worker env vars.
# Copy to `.env` and fill in values. Host platforms (Railway/Render/Fly)
# accept these as secrets — in that case, don't commit a populated .env.

# ── Supabase (service role — bypasses RLS, required for job claim/update) ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Worker auth ────────────────────────────────────────────────────────
# Shared secret validated on every non-/health endpoint. Must match the
# `PIPELINE_WORKER_SECRET` set on the Next.js web app AND the pg_cron GUC
# `app.settings.pipeline_worker_secret`.
PIPELINE_WORKER_SECRET=

# ── CIP pipeline upstream APIs ─────────────────────────────────────────
BRIGHTDATA_API_TOKEN=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Match recompute trigger ────────────────────────────────────────────
# Public URL of the Next.js web app. After the creator fanout for a brand
# is fully drained, the worker POSTs /api/matching/compute here.
WEB_APP_URL=https://<your-web-app-host>
# Optional: if your /api/matching/compute endpoint requires a shared secret,
# set it here and check for it server-side. Leave blank if unauthenticated.
MATCHING_COMPUTE_SECRET=
