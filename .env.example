# Pipeline worker env vars.
# Copy to `.env` and fill in values. Host platforms (Railway/Render/Fly)
# accept these as secrets — in that case, don't commit a populated .env.

# ── Supabase (service role — bypasses RLS, required for job claim/update) ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Worker auth ────────────────────────────────────────────────────────
# Shared secret validated on every non-/health endpoint. Must match the
# `PIPELINE_WORKER_SECRET` set on the Next.js web app AND the pg_cron GUC
# `app.settings.pipeline_worker_secret`.
PIPELINE_WORKER_SECRET=

# ── CIP pipeline upstream APIs ─────────────────────────────────────────
# Instagram scraping is Apify-only — BrightData was retired in the
# pipeline rewrite. The default actor is apify/instagram-scraper.
APIFY_TOKEN=
APIFY_ACTOR_INSTAGRAM=apify/instagram-scraper
# Used by the single-post scraper (handle_content_video_analysis).
APIFY_ACTOR_IG_POST=apify/instagram-post-scraper
# YouTube uses the Data API v3. Provide one or more keys; the pool
# rotates on quota exhaustion (10k units/key/day default).
YOUTUBE_API_KEYS=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Match recompute trigger ────────────────────────────────────────────
# Public URL of the Next.js web app. After the creator fanout for a brand
# is fully drained, the worker POSTs /api/matching/compute here.
WEB_APP_URL=https://<your-web-app-host>
# Optional: if your /api/matching/compute endpoint requires a shared secret,
# set it here and check for it server-side. Leave blank if unauthenticated.
MATCHING_COMPUTE_SECRET=

# ── Apify webhook FSM (Phase 2) ────────────────────────────────────────
# Enable webhook-driven IG creator scrapes. With APIFY_WEBHOOKS=0 the
# legacy synchronous polling path runs. Flip to 1 to canary the new flow.
APIFY_WEBHOOKS=0
# Public URL of THIS worker — Apify hits ${WORKER_PUBLIC_URL}/apify-webhook
# when a run finishes. Must be reachable from the internet.
WORKER_PUBLIC_URL=https://<your-worker-host>
# Shared secret embedded in the webhook URL query string; rejected if
# absent or mismatched.
APIFY_WEBHOOK_SECRET=
# Recovery sweep poll-once threshold for paused IG jobs (minutes).
APIFY_WEBHOOK_MAX_MIN=25

# ── Modal Whisper sidecar (Phase 3) ────────────────────────────────────
# Modal credentials (server-friendly: set both; alternatively use a
# ~/.modal.toml file for local dev). Get them via `modal token new`.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
# App and function names on the deployed Modal app — override only if
# you renamed the app in modal/whisper_service.py.
WHISPER_MODAL_APP_NAME=whisper-transcribe
WHISPER_MODAL_FUNCTION_NAME=transcribe
# WHISPER_ASYNC=1 defers transcription to background jobs. The CIP
# pipeline scores immediately without transcripts and an audience_refresh
# job re-runs LLM eval once async transcripts land.
WHISPER_ASYNC=0

# ── Merged LLM call (Phase 4) ──────────────────────────────────────────
# LLM_MERGED=1 collapses the three Gemini calls (captions/transcripts/
# comments) into one Claude Sonnet 4.6 request with prompt caching.
# Default off — flip to 1 once side-by-side A/B confirms quality parity.
LLM_MERGED=0
LLM_MERGED_MODEL=claude-sonnet-4-6
# One-line fallback when Sonnet cost is too high; Haiku 4.5 is ~5x cheaper.
LLM_MERGED_FALLBACK_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
